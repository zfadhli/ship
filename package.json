{
  "name": "@zfadhli/ship",
  "type": "module",
  "version": "0.3.0",
  "private": true,
  "description": "Release automation — changelog generation, version bumping, GitHub releases",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zfadhli/ship.git"
  },
  "exports": {
    ".": {
      "types": "./dist/core/index.d.mts",
      "default": "./dist/core/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ship": "./dist/cli/index.mjs"
  },
  "types": "./dist/core/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "ci": "bun run typecheck && bun run lint && bun run test && bun run build",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@zfadhli/koko-cli": "^0.2.0",
    "semver": "^7.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "lefthook": "^2.1.9",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14"
}
